<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="
           http://www.liquibase.org/xml/ns/dbchangelog
           http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.23.xsd">

    <changeSet id="001" author="java_sash">
        <createTable tableName="users">
            <column name="tg_id" type="VARCHAR(255)">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="name" type="VARCHAR(255)"/>
            <column name="created_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP" />
            <column name="updated_at" type="TIMESTAMP"/>
        </createTable>
    </changeSet>

    <changeSet id="002" author="java_sash">
        <createTable tableName="transactions">
            <column name="id" type="UUID">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="display_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="type" type="VARCHAR(255)" />
            <column name="user_id" type="VARCHAR(255)" />
            <column name="category" type="VARCHAR(255)" />
            <column name="amount" type="NUMERIC(19,2)" />
            <column name="comment" type="VARCHAR(255)"/>
            <column name="created_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP"/>
            <column name="updated_at" type="TIMESTAMP"/>
        </createTable>

        <addForeignKeyConstraint
                baseTableName="transactions"
                baseColumnNames="user_id"
                referencedTableName="users"
                referencedColumnNames="tg_id"
                constraintName="fk_transactions_user"/>
    </changeSet>

    <changeSet id="003" author="java_sash">
        <createTable tableName="user_display_id_seq">
            <column name="user_id" type="VARCHAR(255)">
                <constraints primaryKey="true" nullable="false"
                             foreignKeyName="fk_seq_user"
                             referencedTableName="users"
                             referencedColumnNames="tg_id"/>
            </column>
            <column name="current_seq" type="BIGINT" defaultValueNumeric="0">
                <constraints nullable="false"/>
            </column>
            <column name="created_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP"/>
            <column name="updated_at" type="TIMESTAMP"/>
        </createTable>
    </changeSet>

    <changeSet id="004" author="java_sash">
        <createIndex indexName="idx_transactions_user_display" tableName="transactions">
            <column name="user_id"/>
            <column name="display_id"/>
        </createIndex>
    </changeSet>

    <changeSet id="005" author="java_sash">
        <createIndex indexName="idx_transactions_user_type" tableName="transactions">
            <column name="user_id"/>
            <column name="type"/>
        </createIndex>
    </changeSet>
</databaseChangeLog>
